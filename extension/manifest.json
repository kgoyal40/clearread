{
  "manifest_version": 3,
  "name": "Unslant",
  "version": "1.0.0",
  "description": "Analyse any news article for bias, credibility, and missing context.",
  "permissions": ["activeTab", "sidePanel", "scripting"],
  "side_panel": {
    "default_path": "dist/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Unslant — Analyse this page"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
