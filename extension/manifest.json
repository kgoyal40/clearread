{
  "manifest_version": 3,
  "name": "ClearRead",
  "version": "1.0.0",
  "description": "Understand, verify, and trust what you read. Analyse any article for reliability and bias.",
  "permissions": ["activeTab", "sidePanel", "scripting"],
  "host_permissions": ["https://clearread-production-b455.up.railway.app/*"],
  "side_panel": {
    "default_path": "dist/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ClearRead — Analyse this page"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
